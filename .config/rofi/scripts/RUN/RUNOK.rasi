/**
* ┌─┐┌─┐┌┐┌┬ ┬┌─┐┬─┐┬┌─┌─┐
* ┌─┘├┤ │││││││ │├┬┘├┴┐└─┐
* └─┘└─┘┘└┘└┴┘└─┘┴└─┴ ┴└─┘
* https://github.com/kbuckleys/ */

@theme "ZENON"

* {
    selected-normal-background: #fab387;
}

window {
    location: south;
    anchor: south;
    width: 600px;
}

mainbox {
    children: [ message, listview ];
}

textbox {
    text-color: #000000;
    horizontal-align: 0.5;
    font: "0xProto Nerd Font Bold 12";
}

listview {
    fixed-height: false;
    scrollbar: false;
    columns: 3;
    lines: 1;
}

element {
    padding: 2px 8px 2px 8px;
}
element-text {
    text-color: #fab387;
    horizontal-align: 0.5;
}
element-text.selected.normal {
    text-color: #000000;
}

message {
    background-color: #fab387;
    padding: 4px;
}
